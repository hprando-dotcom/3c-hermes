POSTGRES_DB=hermes
POSTGRES_USER=hermes
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

HERMES_APP_NAME=HERMES
HERMES_ENVIRONMENT=development
HERMES_VERSION=0.1.0
HERMES_DATABASE_URL=postgresql+psycopg://hermes:change-me@postgres:5432/hermes
HERMES_DATABASE_POOL_SIZE=10
HERMES_DATABASE_MAX_OVERFLOW=20

HERMES_API_HOST=0.0.0.0
HERMES_API_PORT=8000

HERMES_LOG_LEVEL=INFO
HERMES_LOG_FORMAT=json

HERMES_ENABLE_SCHEDULER=true
HERMES_SCHEDULER_TIMEZONE=America/Sao_Paulo
HERMES_COLLECTOR_INTERVAL_SECONDS=900
HERMES_COLLECTOR_INITIAL_LOOKBACK_DAYS=30

HERMES_CLASSIFIER_PROVIDER=keyword
HERMES_DEEPSEEK_API_KEY=

SP_DOE_CONSUMER_KEY=
SP_DOE_CONSUMER_SECRET=
SP_DOE_TOKEN_URL=
